load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
load("@ecos_bazel_rules//rules:python_packaging.bzl", "cpp_runtime_bundle")

package(default_visibility = ["//visibility:public"])

cmake(
    name = "ecc_py_cmake",
    lib_source = "@ecc_tools_src//:all_sources",
    cache_entries = {
        "BUILD_AIEDA": "ON",
        "BUILD_PYTHON": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        # Use venv Python so the built .so matches chipcompiler's Python ABI
        "Python3_EXECUTABLE": "$$EXT_BUILD_ROOT$$/.venv/bin/python",
    },
    targets = ["ecc_py"],
    install = False,
    # Why: ecc_py.so has a dynamic Python ABI suffix (e.g. cpython-311-x86_64-linux-gnu).
    # The .so is output to the source dir (ecc_tools_src/bin/), not the build dir.
    # Copy ecc_py*.so and all runtime .so libs into $INSTALLDIR/lib.
    postfix_script = """
        mkdir -p $$INSTALLDIR/lib
        find $$EXT_BUILD_ROOT/external -name 'ecc_py*.so' -exec cp -f {} $$INSTALLDIR/lib/ \\;
        find . -name '*.so' -exec cp -f {} $$INSTALLDIR/lib/ \\;
    """,
    out_headers_only = True,
    generate_args = ["-GNinja"],
    out_data_dirs = ["lib"],
)

cpp_runtime_bundle(
    name = "runtime_bundle",
    cmake_target = ":ecc_py_cmake",
    dest_bin_dir = "chipcompiler/tools/ecc/bin",
    dest_lib_dir = "chipcompiler/tools/ecc/bin/lib",
    so_pattern = "ecc_py*.so",
    autopatch_script = "@ecos_bazel_rules//tools:autopatch_runtime",
    auto_patchelf_bin = "@ecos_bazel_rules//tools/auto-patchelf:auto_patchelf",
    patchelf = "@patchelf//:bin/patchelf",
)
